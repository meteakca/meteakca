<div class="blog-listing">
<% for (const item of items) { %>
<a href="<%= item.path %>" class="blog-item">
  <span class="blog-date"><%= item.date ? new Date(item.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '' %></span>
  <span class="blog-title"><%= item.title %></span>
  <span class="blog-desc"><%= item.description || '' %></span>
</a>
<% } %>
</div>
